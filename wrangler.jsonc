{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my-projects-rest-api",
	"main": "src/index.js",
	"compatibility_date": "2026-03-12",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "projects_db",
			"database_id": "cd5d1bb5-7661-4b4b-904c-27b4f6824de3",
			"migrations_dir": "./src/data/migrations"
		},
	],
	"ratelimits": [
			{
				"name": "AUTH_LIMITER",
				"namespace_id": "1001",
				"simple": {
					"limit": 10,
					"period": 60,
				},
			},
  ],
}